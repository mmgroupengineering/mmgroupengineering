---
layout: layouts/base.njk
title: Services
nav: services
permalink: /services/
description: Marine repair and engineering services — dry dock, teams, and facilities.
---

<section class="page-hero page-hero--compact">
  <div class="content-width">
    <h1 class="page-hero__title">Services</h1>
    <p class="page-hero__lead">{{ site.servicesIntro }}</p>
  </div>
</section>

<section class="section section--tight service-index-section" aria-label="Service list">
  <div class="content-width">
    <ul class="service-index">
      {% for item in services %}
        <li class="service-index__item">
          <a
            class="service-index__row{% if loop.index0 % 2 == 1 %} service-index__row--reverse{% endif %}"
            href="{{ ('/services/' ~ item.slug ~ '/') | url }}"
          >
            <div class="service-index__figure">
              <img
                class="service-index__img"
                src="{{ (item.mainImage | default(item.image)) | url }}"
                alt=""
                width="720"
                height="432"
                loading="lazy"
                decoding="async"
              >
            </div>
            <div class="service-index__content">
              <h2 class="service-index__title">{{ item.title }}</h2>
              <p class="service-index__excerpt">{{ item.paragraphs[0] }}</p>
              <span class="service-index__action">
                Explore
                <span class="service-index__arrow" aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
